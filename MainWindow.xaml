<Window x:Class="Vimina.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Vimina" 
        Height="260" Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1a1a2e"
        Foreground="#e0e0e0"
        FontFamily="Microsoft YaHei UI">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Alt+F 显示标记" 
                   Margin="20,20,20,5"
                   FontSize="14"
                   Foreground="#e0e0e0"/>

        <TextBlock Grid.Row="1" 
                   Text="Esc 清除 | Alt+R 刷新" 
                   Margin="20,5,20,5"
                   FontSize="12"
                   Foreground="#666666"/>

        <TextBlock Grid.Row="2" 
                   Text="输入标签字母点击对应控件" 
                   Margin="20,5,20,5"
                   FontSize="12"
                   Foreground="#888888"/>

        <TextBlock Grid.Row="3" 
                   x:Name="ApiStatusText"
                   Text="API: 启动中..." 
                   Margin="20,5,20,5"
                   FontSize="12"
                   Foreground="#008800"/>

        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,20">
            <Button x:Name="BtnConfig"
                    Content="配置"
                    Width="80" Height="32"
                    Margin="5"
                    Background="#2a2a4a"
                    Foreground="#e0e0e0"
                    BorderBrush="#3a3a5c"
                    Click="BtnConfig_Click"/>
            <Button x:Name="BtnScript"
                    Content="脚本"
                    Width="60" Height="32"
                    Margin="5"
                    Background="#2a2a4a"
                    Foreground="#e0e0e0"
                    BorderBrush="#3a3a5c"
                    Click="BtnScript_Click"/>
        </StackPanel>
    </Grid>
</Window>
