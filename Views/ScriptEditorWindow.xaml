<Window x:Class="Vimina.Views.ScriptEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📝 VMA 脚本编辑器" 
        Height="700" Width="900"
        MinHeight="500" MinWidth="600"
        Background="#0f0f1a"
        Foreground="#e0e0e0"
        FontFamily="Microsoft YaHei UI">
    
    <Window.Resources>
        <!-- 按钮样式 -->
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a0a0b0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2d2d4a"/>
                    <Setter Property="Foreground" Value="#e0e0e0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00d4ff"/>
            <Setter Property="Foreground" Value="#0f0f1a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33ddff"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2d2d4a"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3d3d5a"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- 分隔线样式 -->
        <Style x:Key="SeparatorStyle" TargetType="Separator">
            <Setter Property="Background" Value="#2d2d4a"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Width" Value="1"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="150"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" Height="50" Background="#1a1a2e">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📝" FontSize="20" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="VMA 脚本编辑器" FontSize="16" FontWeight="SemiBold" Foreground="#ffffff"/>
                        <TextBlock x:Name="FileNameText" Text="未命名.vma" FontSize="11" Foreground="#666666"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="就绪" FontSize="12" Foreground="#00d4ff" Margin="0,0,15,0"/>
                    <TextBlock Text="v1.5.0" FontSize="11" Foreground="#444444"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- 工具栏 -->
        <Border Grid.Row="1" Height="45" Background="#161625" BorderBrush="#2d2d4a" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                <Button Content="📄 新建" Style="{StaticResource ToolButtonStyle}" Click="BtnNew_Click"/>
                <Button Content="📂 打开" Style="{StaticResource ToolButtonStyle}" Click="BtnOpen_Click"/>
                <Button Content="💾 保存" Style="{StaticResource ToolButtonStyle}" Click="BtnSave_Click"/>
                <Separator Style="{StaticResource SeparatorStyle}"/>
                <Button Content="▶️ 运行" Style="{StaticResource ActionButtonStyle}" Click="BtnRun_Click"/>
                <Button Content="🔨 编译" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="BtnCompile_Click"/>
                <Separator Style="{StaticResource SeparatorStyle}"/>
                <Button Content="⏹️ 停止" Style="{StaticResource ToolButtonStyle}" Click="BtnStop_Click"/>
            </StackPanel>
        </Border>
        
        <!-- 编辑器区域 -->
        <Border Grid.Row="2" Background="#0d0d1a" Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- 行号 -->
                <Border Grid.Column="0" Background="#0a0a15" BorderBrush="#1a1a2e" BorderThickness="0,0,1,0">
                    <TextBox x:Name="LineNumbers"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="#444444"
                             FontFamily="Consolas"
                             FontSize="14"
                             BorderThickness="0"
                             Text="1"
                             VerticalAlignment="Top"
                             Padding="8,5,8,5"
                             TextAlignment="Right"/>
                </Border>
                
                <!-- 代码编辑器 -->
                <TextBox Grid.Column="1"
                         x:Name="Editor"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Consolas"
                         FontSize="14"
                         Background="Transparent"
                         Foreground="#e0e0e0"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Padding="10,5"
                         CaretBrush="#00d4ff"
                         Text=""
                         TextChanged="Editor_TextChanged"
                         ScrollViewer.ScrollChanged="Editor_ScrollChanged"/>
            </Grid>
        </Border>
        
        <!-- 分隔条 -->
        <Border Grid.Row="3" Height="6" Background="#0f0f1a" Cursor="SizeNS"/>
        
        <!-- 输出面板 -->
        <Border Grid.Row="4" Background="#0d0d1a" BorderBrush="#2d2d4a" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- 输出面板标题栏 -->
                <Border Grid.Row="0" Background="#161625">
                    <Grid Margin="10,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📋" Margin="0,0,6,0"/>
                            <TextBlock Text="输出" FontSize="12" Foreground="#a0a0b0"/>
                            <TextBlock x:Name="OutputStats" Text="" FontSize="11" Foreground="#666666" Margin="10,0,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="🗑️ 清空" 
                                Style="{StaticResource ToolButtonStyle}" 
                                Padding="8,2"
                                Click="BtnClearOutput_Click"/>
                    </Grid>
                </Border>
                
                <!-- 输出内容 -->
                <TextBox Grid.Row="1"
                         x:Name="Output"
                         IsReadOnly="True"
                         FontFamily="Consolas"
                         FontSize="12"
                         Background="Transparent"
                         Foreground="#888888"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         Padding="10"
                         Text="等待脚本执行..."/>
            </Grid>
        </Border>
    </Grid>
</Window>
