<Window x:Class="Vimina.Views.ScriptEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="VMA 脚本编辑器" 
        Height="700" Width="900"
        MinHeight="500" MinWidth="600"
        Background="Transparent"
        Foreground="#e0e0e0"
        FontFamily="Microsoft YaHei UI"
        WindowStyle="None"
        AllowsTransparency="True">
    
    <Window.Resources>
        <Style x:Key="ToolButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a0a0b0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2d2d4a"/>
                    <Setter Property="Foreground" Value="#e0e0e0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#00d4ff"/>
            <Setter Property="Foreground" Value="#0f0f1a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33ddff"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2d2d4a"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3d3d5a"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="SeparatorStyle" TargetType="Separator">
            <Setter Property="Background" Value="#2d2d4a"/>
            <Setter Property="Margin" Value="8,0"/>
            <Setter Property="Width" Value="1"/>
        </Style>
        
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#00d4ff"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding ItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  Margin="10,0,0,0"/>
                                                <Path Grid.Column="1"
                                                      x:Name="Arrow"
                                                      Fill="#00d4ff"
                                                      Data="M 0 0 L 6 6 L 12 0 Z"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#33ddff"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="#33ddff"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="Data" Value="M 0 6 L 6 0 L 12 6 Z"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide"
                                   StaysOpen="False">
                                <Border x:Name="DropDownBorder"
                                        Background="#1a1a2e"
                                        BorderBrush="#00d4ff"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="400">
                                    <ScrollViewer Margin="0,4"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ScrollViewer.Resources>
                                            <Style TargetType="ScrollBar">
                                                <Setter Property="Background" Value="#1a1a2e"/>
                                                <Setter Property="Foreground" Value="#2d2d4a"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ScrollBar">
                                                            <Grid Background="{TemplateBinding Background}">
                                                                <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                                    <Track.DecreaseRepeatButton>
                                                                        <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                                                    </Track.DecreaseRepeatButton>
                                                                    <Track.Thumb>
                                                                        <Thumb>
                                                                            <Thumb.Template>
                                                                                <ControlTemplate>
                                                                                    <Border Background="#2d2d4a" 
                                                                                            CornerRadius="6"
                                                                                            Margin="2,0"/>
                                                                                </ControlTemplate>
                                                                            </Thumb.Template>
                                                                        </Thumb>
                                                                    </Track.Thumb>
                                                                    <Track.IncreaseRepeatButton>
                                                                        <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                                                    </Track.IncreaseRepeatButton>
                                                                </Track>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="Orientation" Value="Horizontal">
                                                        <Setter Property="Height" Value="12"/>
                                                        <Setter Property="Width" Value="Auto"/>
                                                    </Trigger>
                                                    <Trigger Property="Orientation" Value="Vertical">
                                                        <Setter Property="Width" Value="12"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ScrollViewer.Resources>
                                        <ItemsPresenter x:Name="ItemsPresenter"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#e0e0e0"/>
                        <Setter Property="Padding" Value="12,8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Border"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Left"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#2d2d4a"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Border" Property="Background" Value="#00d4ff"/>
                                            <Setter Property="Foreground" Value="#0f0f1a"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Border Background="#0f0f1a" 
            BorderBrush="#00d4ff" 
            BorderThickness="1" 
            CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>
            
            <Border Grid.Row="0" 
                    Height="50" 
                    Background="#1a1a2e"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="15,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="VMA 脚本编辑器" FontSize="16" FontWeight="SemiBold" Foreground="#00d4ff"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="FileNameText" Text="未命名.vma" FontSize="11" Foreground="#666666"/>
                                <TextBlock x:Name="StatusText" Text="就绪" FontSize="11" Foreground="#00d4ff" Margin="10,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" 
                            Content="-" 
                            Width="32" 
                            Height="32"
                            Background="Transparent"
                            Foreground="#888888"
                            BorderThickness="0"
                            FontSize="18"
                            Click="BtnMinimize_Click"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                    <Button Grid.Column="2" 
                            Content="□" 
                            Width="32" 
                            Height="32"
                            Background="Transparent"
                            Foreground="#888888"
                            BorderThickness="0"
                            FontSize="14"
                            Click="BtnMaximize_Click"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                    <Button Grid.Column="3" 
                            Content="x" 
                            Width="32" 
                            Height="32"
                            Background="Transparent"
                            Foreground="#888888"
                            BorderThickness="0"
                            FontSize="14"
                            Click="BtnClose_Click"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                </Grid>
            </Border>
            
            <Border Grid.Row="1" Height="45" Background="#161625" BorderBrush="#2d2d4a" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">
                    <Button Content="新建" Style="{StaticResource ToolButtonStyle}" Click="BtnNew_Click"/>
                    <Button Content="打开" Style="{StaticResource ToolButtonStyle}" Click="BtnOpen_Click"/>
                    <Button Content="保存" Style="{StaticResource ToolButtonStyle}" Click="BtnSave_Click"/>
                    
                    <ComboBox x:Name="FunctionComboBox" 
                              Width="180" 
                              Height="30"
                              Margin="12,0,12,0"
                              Background="#1a1a2e"
                              Foreground="#e0e0e0"
                              BorderBrush="#00d4ff"
                              BorderThickness="1"
                              FontSize="12"
                              SelectionChanged="FunctionComboBox_SelectionChanged"
                              Style="{StaticResource DarkComboBoxStyle}">
                    </ComboBox>
                    
                    <Button Content="运行" Style="{StaticResource ActionButtonStyle}" Click="BtnRun_Click"/>
                    <Button Content="编译" Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0" Click="BtnCompile_Click"/>
                    <Separator Style="{StaticResource SeparatorStyle}"/>
                    <Button Content="停止" Style="{StaticResource ToolButtonStyle}" Click="BtnStop_Click"/>
                </StackPanel>
            </Border>
            
            <Border Grid.Row="2" Background="#0d0d1a" Margin="10">
                <avalonEdit:TextEditor x:Name="Editor"
                                       FontFamily="Consolas"
                                       FontSize="14"
                                       Background="#0d0d1a"
                                       Foreground="#e0e0e0"
                                       BorderThickness="0"
                                       Padding="10,5"
                                       ShowLineNumbers="True"
                                       LineNumbersForeground="#444444"
                                       SyntaxHighlighting="VMA"
                                       TextChanged="Editor_TextChanged">
                    <avalonEdit:TextEditor.Resources>
                    <Style TargetType="ScrollBar">
                        <Setter Property="Background" Value="#0d0d1a"/>
                        <Setter Property="Foreground" Value="#2d2d4a"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollBar">
                                    <Grid Background="{TemplateBinding Background}">
                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0"/>
                                            </Track.DecreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate>
                                                            <Border Background="#2d2d4a" 
                                                                    CornerRadius="6"
                                                                    Margin="2,0"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0"/>
                                            </Track.IncreaseRepeatButton>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="12"/>
                                <Setter Property="Width" Value="Auto"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="Width" Value="12"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Background" Value="#0d0d1a"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ScrollViewer">
                                    <Grid Background="{TemplateBinding Background}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <ScrollContentPresenter Grid.Column="0" Grid.Row="0"/>
                                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                                   Grid.Column="1" Grid.Row="0"
                                                   Orientation="Vertical"
                                                   Value="{TemplateBinding VerticalOffset}"
                                                   Maximum="{TemplateBinding ScrollableHeight}"
                                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                                   Grid.Column="0" Grid.Row="1"
                                                   Orientation="Horizontal"
                                                   Value="{TemplateBinding HorizontalOffset}"
                                                   Maximum="{TemplateBinding ScrollableWidth}"
                                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                                        <Border Grid.Column="1" Grid.Row="1" 
                                                Background="#0d0d1a" 
                                                Width="12" 
                                                Height="12"/>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </avalonEdit:TextEditor.Resources>
                <avalonEdit:TextEditor.Options>
                    <avalonEdit:TextEditorOptions EnableVirtualSpace="False"
                                                  WordWrapIndentation="4"
                                                  InheritWordWrapIndentation="True"
                                                  ShowSpaces="False"
                                                  ShowTabs="False"
                                                  ShowEndOfLine="False"
                                                  HighlightCurrentLine="True"
                                                  EnableRectangularSelection="True"
                                                  EnableTextDragDrop="True"
                                                  EnableHyperlinks="False"
                                                  CutCopyWholeLine="True"
                                                  ConvertTabsToSpaces="False"
                                                  IndentationSize="4"/>
                </avalonEdit:TextEditor.Options>
                </avalonEdit:TextEditor>
            </Border>
            
            <Border Grid.Row="3" Height="6" Background="#0f0f1a" Cursor="SizeNS"/>
            
            <Border Grid.Row="4" 
                    Background="#0d0d1a" 
                    BorderBrush="#2d2d4a" 
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="30"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#161625">
                        <Grid Margin="10,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="输出" FontSize="12" Foreground="#a0a0b0"/>
                                <TextBlock x:Name="OutputStats" Text="" FontSize="11" Foreground="#666666" Margin="10,0,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="清空" 
                                    Style="{StaticResource ToolButtonStyle}" 
                                    Padding="8,2"
                                    Click="BtnClearOutput_Click"/>
                        </Grid>
                    </Border>
                    
                    <TextBox Grid.Row="1"
                             x:Name="Output"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             Background="Transparent"
                             Foreground="#888888"
                             BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"
                             Padding="10"
                             Text="等待脚本执行..."/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
