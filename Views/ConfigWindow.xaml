<Window x:Class="Vimina.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙️ Vimina 配置" 
        Height="600" Width="700"
        ResizeMode="CanResize"
        MinHeight="500" MinWidth="600"
        WindowStartupLocation="CenterOwner"
        Background="#0f0f1a"
        Foreground="#e0e0e0"
        FontFamily="Microsoft YaHei UI">
    
    <Window.Resources>
        <!-- 样式资源 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="BorderBrush" Value="#2d2d4a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
        
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#00d4ff"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#a0a0b0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#0f0f1a"/>
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="BorderBrush" Value="#2d2d4a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="#00d4ff"/>
        </Style>
        
        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#e0e0e0"/>
            <Setter Property="Margin" Value="0,6"/>
        </Style>
        
        <Style x:Key="ButtonPrimaryStyle" TargetType="Button">
            <Setter Property="Background" Value="#00d4ff"/>
            <Setter Property="Foreground" Value="#0f0f1a"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#33ddff"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <Style x:Key="ButtonSecondaryStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#a0a0b0"/>
            <Setter Property="BorderBrush" Value="#2d2d4a"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2d2d4a"/>
                    <Setter Property="Foreground" Value="#e0e0e0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid>
        <!-- 标题栏 -->
        <Border Height="60" Background="#1a1a2e" VerticalAlignment="Top" Panel.ZIndex="1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="⚙️ Vimina 配置" FontSize="20" FontWeight="Bold" Foreground="#ffffff"/>
                    <TextBlock Text="自定义控件扫描和点击行为" FontSize="12" Foreground="#888888" Margin="0,2,0,0"/>
                </StackPanel>
                <TextBlock Grid.Column="1" Text="v1.5.0" FontSize="12" Foreground="#666666" VerticalAlignment="Center"/>
            </Grid>
        </Border>
        
        <!-- 内容区域 -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,60,0,70">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- 左列 -->
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <!-- 点击模式 -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="🖱️ 点击模式" Style="{StaticResource SectionHeaderStyle}"/>
                            <CheckBox x:Name="ChkMouseClick" Style="{StaticResource CheckBoxStyle}">
                                <TextBlock>
                                    <Run Text="使用鼠标点击" FontWeight="SemiBold"/>
                                    <Run Text=" (UseMouseClick)" Foreground="#666666" FontSize="11"/>
                                </TextBlock>
                            </CheckBox>
                            <TextBlock Text="直接使用鼠标事件进行点击，不依赖 FlaUI" 
                                      Foreground="#666666" FontSize="11" Margin="20,0,0,8" TextWrapping="Wrap"/>
                            
                            <CheckBox x:Name="ChkBringFront" Style="{StaticResource CheckBoxStyle}" IsChecked="True">
                                <TextBlock>
                                    <Run Text="点击前激活窗口" FontWeight="SemiBold"/>
                                    <Run Text=" (BringToFront)" Foreground="#666666" FontSize="11"/>
                                </TextBlock>
                            </CheckBox>
                            <TextBlock Text="点击前将目标窗口带到前台" 
                                      Foreground="#666666" FontSize="11" Margin="20,0,0,8" TextWrapping="Wrap"/>
                            
                            <CheckBox x:Name="ChkFlaUI" Style="{StaticResource CheckBoxStyle}" IsChecked="True">
                                <TextBlock>
                                    <Run Text="使用 FlaUI 后台点击" FontWeight="SemiBold"/>
                                    <Run Text=" (UseFlaUIClick)" Foreground="#666666" FontSize="11"/>
                                </TextBlock>
                            </CheckBox>
                            <TextBlock Text="使用 FlaUI 框架进行后台点击，不移动鼠标" 
                                      Foreground="#666666" FontSize="11" Margin="20,0,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- 性能设置 -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="⚡ 性能设置" Style="{StaticResource SectionHeaderStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="点击延迟" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="每次点击后的等待时间（毫秒）" 
                                              Foreground="#666666" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" x:Name="TxtClickDelay" Text="30" 
                                        Style="{StaticResource InputStyle}" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- 过滤设置 -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="🔍 控件过滤" Style="{StaticResource SectionHeaderStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="最小宽度 (像素)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Grid.Column="1" x:Name="TxtMinWidth" Text="8" 
                                        Style="{StaticResource InputStyle}"/>
                            </Grid>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="最小高度 (像素)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Grid.Column="1" x:Name="TxtMinHeight" Text="8" 
                                        Style="{StaticResource InputStyle}"/>
                            </Grid>
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="最大深度" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="控件树遍历的最大层级" 
                                              Foreground="#666666" FontSize="11" TextWrapping="Wrap"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" x:Name="TxtMaxDepth" Text="50" 
                                        Style="{StaticResource InputStyle}" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <!-- 右列 -->
                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <!-- 颜色设置 -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="🎨 标签颜色" Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBlock Text="格式: 0xRRGGBB" Foreground="#666666" FontSize="11" Margin="0,0,0,10"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="16" Height="16" Fill="#00DDFF" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="默认" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" x:Name="TxtColorDefault" Text="0x00DDFF" 
                                        Style="{StaticResource InputStyle}"/>
                            </Grid>
                            
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="16" Height="16" Fill="#00FF00" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="匹配" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" x:Name="TxtColorMatch" Text="0x00FF00" 
                                        Style="{StaticResource InputStyle}"/>
                            </Grid>
                            
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="16" Height="16" Fill="#00A5FF" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="前缀" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" x:Name="TxtColorPrefix" Text="0x00A5FF" 
                                        Style="{StaticResource InputStyle}"/>
                            </Grid>
                            
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="16" Height="16" Fill="#808080" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="无效" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" x:Name="TxtColorInvalid" Text="0x808080" 
                                        Style="{StaticResource InputStyle}"/>
                            </Grid>
                            
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Width="16" Height="16" Fill="#000000" Margin="0,0,10,0"/>
                                <TextBlock Grid.Column="1" Text="文字" VerticalAlignment="Center"/>
                                <TextBox Grid.Column="2" x:Name="TxtColorText" Text="0x000000" 
                                        Style="{StaticResource InputStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <!-- 标签字体 -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="🔤 标签样式" Style="{StaticResource SectionHeaderStyle}"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="字体大小 (像素)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Grid.Column="1" x:Name="TxtFontSize" Text="12" 
                                        Style="{StaticResource InputStyle}"/>
                            </Grid>
                            
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="字体粗细" Style="{StaticResource LabelStyle}"/>
                                    <TextBlock Text="100-900，700=粗体" 
                                              Foreground="#666666" FontSize="11"/>
                                </StackPanel>
                                <TextBox Grid.Column="1" x:Name="TxtFontWeight" Text="700" 
                                        Style="{StaticResource InputStyle}" VerticalAlignment="Center"/>
                            </Grid>
                            
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="X 偏移 (像素)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Grid.Column="1" x:Name="TxtOffsetX" Text="0" 
                                        Style="{StaticResource InputStyle}"/>
                            </Grid>
                            
                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Y 偏移 (像素)" Style="{StaticResource LabelStyle}"/>
                                <TextBox Grid.Column="1" x:Name="TxtOffsetY" Text="18" 
                                        Style="{StaticResource InputStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
        
        <!-- 底部按钮栏 -->
        <Border Height="70" Background="#1a1a2e" VerticalAlignment="Bottom" BorderBrush="#2d2d4a" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,0">
                <Button Content="❌ 取消" Style="{StaticResource ButtonSecondaryStyle}" Margin="0,0,10,0" Click="BtnCancel_Click"/>
                <Button Content="💾 保存配置" Style="{StaticResource ButtonPrimaryStyle}" Click="BtnSave_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
